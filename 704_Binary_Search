class Solution {
public:
    int search(vector<int>& nums, int target) {
        
        int low = 0;
        int high = nums.size()-1;
        int mid;
        
        while(low<=high){
            mid = (low+high)/2;
            if(nums[mid] == target){
                return mid;
            }            
            if(target > nums[mid]){
                low = mid+1;
            } else high=high-1;
        }
        return -1;
    }
};
